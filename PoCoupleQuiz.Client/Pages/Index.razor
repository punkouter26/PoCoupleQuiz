@page "/"
@using PoCoupleQuiz.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject NavigationManager NavigationManager
@inject IGameHubService Hub
@inject ILogger<Pages.Index> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>PoCoupleQuiz</PageTitle>

<style>
    .lobby-home-wrapper {
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-4);
        background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--color-accent-50) 100%);
    }

    .lobby-home-card {
        background: var(--surface);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-xl);
        padding: var(--space-8);
        max-width: 560px;
        width: 100%;
        animation: slideInUp var(--transition-slow) ease-out;
    }

    .lobby-home-header {
        text-align: center;
        margin-bottom: var(--space-8);
    }

    .lobby-home-title {
        font-size: var(--font-size-3xl);
        font-weight: var(--font-weight-bold);
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: var(--space-2);
    }

    .lobby-home-subtitle {
        font-size: var(--font-size-base);
        color: var(--color-neutral-500);
    }

    .identity-card {
        background: var(--color-primary-50);
        border: 2px solid var(--color-primary-200);
        border-radius: var(--radius-lg);
        padding: var(--space-4);
        margin-bottom: var(--space-6);
    }

    .identity-label {
        font-size: var(--font-size-xs);
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-neutral-500);
        margin-bottom: var(--space-1);
    }

    .identity-value {
        font-size: var(--font-size-xl);
        color: var(--color-primary-700);
        font-weight: var(--font-weight-bold);
    }

    .action-tabs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-2);
        margin-bottom: var(--space-6);
        background: var(--color-neutral-100);
        border-radius: var(--radius-lg);
        padding: var(--space-1);
    }

    .action-tab {
        padding: var(--space-3) var(--space-4);
        border: none;
        border-radius: var(--radius-md);
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm);
        cursor: pointer;
        transition: all var(--transition-base);
        background: transparent;
        color: var(--color-neutral-500);
    }

    .action-tab.active {
        background: var(--surface);
        color: var(--color-primary-600);
        box-shadow: var(--shadow-sm);
    }

    .form-group {
        margin-bottom: var(--space-5);
    }

    .form-group label {
        display: block;
        font-weight: var(--font-weight-semibold);
        color: var(--color-neutral-900);
        margin-bottom: var(--space-2);
        font-size: var(--font-size-sm);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        font-family: inherit;
        font-size: var(--font-size-base);
        border: 2px solid var(--color-neutral-200);
        border-radius: var(--radius-md);
        background-color: #fff;
        color: var(--color-neutral-900);
        transition: all var(--transition-base);
        box-sizing: border-box;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--color-primary-600);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
    }

    .form-control.code-input {
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: var(--font-size-xl);
        font-weight: var(--font-weight-bold);
        text-align: center;
    }

    .difficulty-selector {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-3);
        margin-top: var(--space-2);
    }

    .difficulty-option {
        padding: var(--space-3);
        border: 2px solid var(--color-neutral-200);
        border-radius: var(--radius-md);
        text-align: center;
        cursor: pointer;
        transition: all var(--transition-base);
        background: white;
    }

    .difficulty-option:hover { border-color: var(--color-primary-400); }
    .difficulty-option.selected {
        background: var(--gradient-primary);
        color: white;
        border-color: var(--color-primary-600);
        box-shadow: var(--shadow-primary);
    }

    .difficulty-option .difficulty-name {
        font-weight: var(--font-weight-semibold);
        display: block;
        margin-bottom: var(--space-1);
    }

    .difficulty-option .difficulty-rounds { font-size: var(--font-size-xs); opacity: .7; }

    .btn-primary {
        width: 100%;
        padding: var(--space-4) var(--space-6);
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-bold);
        border: none;
        border-radius: var(--radius-lg);
        background: var(--gradient-primary);
        color: white;
        cursor: pointer;
        transition: all var(--transition-base);
        box-shadow: var(--shadow-primary);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        margin-top: var(--space-6);
    }

    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 15px 40px -5px rgba(139, 92, 246, .4); }
    .btn-primary:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: var(--radius-md);
        padding: var(--space-3) var(--space-4);
        margin-bottom: var(--space-4);
        font-size: var(--font-size-sm);
    }

    .spinner {
        width: 20px; height: 20px;
        border: 3px solid rgba(255,255,255,.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
    @@keyframes slideInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 480px) {
        .lobby-home-card { padding: var(--space-6); }
    }
</style>

<div class="lobby-home-wrapper">
    <div class="lobby-home-card">
        <div class="lobby-home-header">
            <h1 class="lobby-home-title">Multiplayer Lobby</h1>
            <p class="lobby-home-subtitle">Join with at least 2 players, then the host can start the game</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        <div class="identity-card">
            <div class="identity-label">Assigned Player Name</div>
            <div class="identity-value">@assignedPlayerName</div>
        </div>

        <div class="action-tabs">
            <button class="action-tab @(actionTab == "new" ? "active" : "")" @onclick='() => actionTab = "new"'>Host Lobby</button>
            <button class="action-tab @(actionTab == "join" ? "active" : "")" @onclick='() => actionTab = "join"'>Join Lobby</button>
        </div>

        @if (actionTab == "join")
        {
            <div class="form-group">
                <label>Game Code</label>
                <input @bind="joinCode" @bind:event="oninput" class="form-control code-input"
                       placeholder="XXXX" maxlength="6" />
            </div>
        }

        <button class="btn-primary" @onclick="EnterLobbyAsync" disabled="@isLoading">
            @if (isLoading) { <div class="spinner"></div> }
            else if (actionTab == "new") { <span>🚀 Enter Host Lobby</span> }
            else { <span>🔗 Join Lobby</span> }
        </button>
    </div>
</div>

@code {
    private string actionTab = "new";
    private string assignedPlayerName = "";
    private string joinCode = "";
    private bool isLoading = false;
    private string errorMessage = "";

    private Action<LobbyInfo>? _onLobbyCreated;
    private Action<LobbyInfo>? _onLobbyJoined;
    private Action<string>? _onLobbyError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            assignedPlayerName = authState.User.FindFirst("name")?.Value
                ?? authState.User.Identity.Name
                ?? "";
        }

        if (string.IsNullOrWhiteSpace(assignedPlayerName))
        {
            var suffix = Guid.NewGuid().ToString("N")[..4].ToUpperInvariant();
            assignedPlayerName = $"Player-{suffix}";
        }

        _onLobbyCreated = info =>
        {
            isLoading = false;
            InvokeAsync(() => NavigationManager.NavigateTo($"/lobby/{info.GameCode}"));
        };

        _onLobbyJoined = info =>
        {
            isLoading = false;
            InvokeAsync(() => NavigationManager.NavigateTo($"/lobby/{info.GameCode}"));
        };

        _onLobbyError = msg =>
        {
            isLoading = false;
            errorMessage = msg;
            InvokeAsync(StateHasChanged);
        };

        Hub.OnLobbyCreated += _onLobbyCreated;
        Hub.OnLobbyJoined  += _onLobbyJoined;
        Hub.OnLobbyError   += _onLobbyError;
    }

    private async Task EnterLobbyAsync()
    {
        errorMessage = "";

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/")}", false);
            return;
        }

        isLoading = true;
        StateHasChanged();

        if (actionTab == "join" && string.IsNullOrWhiteSpace(joinCode))
        {
            errorMessage = "Please enter a game code.";
            isLoading = false;
            return;
        }

        try
        {
            if (!Hub.IsConnected)
                await Hub.ConnectAsync();

            if (actionTab == "new")
                await Hub.CreateLobbyAsync(assignedPlayerName, "Medium");
            else
                await Hub.JoinLobbyAsync(joinCode.Trim().ToUpperInvariant(), assignedPlayerName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "EnterLobbyAsync failed");
            errorMessage = "Could not connect. Please try again.";
            isLoading = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Hub.OnLobbyCreated -= _onLobbyCreated;
        Hub.OnLobbyJoined  -= _onLobbyJoined;
        Hub.OnLobbyError   -= _onLobbyError;
    }
}

