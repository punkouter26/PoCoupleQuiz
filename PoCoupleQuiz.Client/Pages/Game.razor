@page "/game/{GameCode}"
@using PoCoupleQuiz.Client.Services
@using PoCoupleQuiz.Core.Models
@using PoCoupleQuiz.Core.Services
@implements IDisposable
@inject IGameHubService Hub
@inject ITeamService TeamService
@inject IGameHistoryService GameHistoryService
@inject NavigationManager NavigationManager
@inject ILogger<Pages.Game> Logger

<PageTitle>PoCoupleQuiz — Round @(roundIndex + 1)</PageTitle>

<style>
    .game-wrapper {
        min-height: calc(100vh - 70px);
        padding: var(--space-4);
        background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--color-accent-50) 100%);
    }

    .game-layout {
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: var(--space-5);
        align-items: start;
        animation: slideInUp var(--transition-slow) ease-out;
    }

    .card {
        background: var(--surface);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        padding: var(--space-6);
        border: 1px solid var(--color-neutral-200);
    }

    .round-badge {
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-semibold);
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-primary-600);
        background: var(--color-primary-50);
        border-radius: 999px;
        padding: 3px 12px;
        display: inline-block;
        margin-bottom: var(--space-4);
    }

    .question-text {
        font-size: var(--font-size-xl);
        font-weight: var(--font-weight-semibold);
        color: var(--color-neutral-900);
        line-height: 1.5;
        margin-bottom: var(--space-6);
    }

    .role-pill {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        border-radius: 999px;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
        margin-bottom: var(--space-4);
    }

    .role-king { background: #fef9c3; color: #713f12; }
    .role-guesser { background: #ede9fe; color: #5b21b6; }

    .answer-area { margin-top: var(--space-2); }

    .answer-input {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        font-size: var(--font-size-base);
        border: 2px solid var(--color-neutral-200);
        border-radius: var(--radius-md);
        background: #fff;
        color: var(--color-neutral-900);
        transition: all var(--transition-base);
        box-sizing: border-box;
        font-family: inherit;
    }

    .answer-input:focus {
        outline: none;
        border-color: var(--color-primary-600);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, .1);
    }

    .btn-submit {
        width: 100%;
        margin-top: var(--space-4);
        padding: var(--space-4);
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-bold);
        border: none;
        border-radius: var(--radius-lg);
        background: var(--gradient-primary);
        color: white;
        cursor: pointer;
        transition: all var(--transition-base);
        box-shadow: var(--shadow-primary);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-submit:hover:not(:disabled) { transform: translateY(-2px); }
    .btn-submit:disabled { opacity: .5; cursor: not-allowed; transform: none; }

    .waiting-box {
        background: var(--color-primary-50);
        border: 2px dashed var(--color-primary-200);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        text-align: center;
        color: var(--color-primary-700);
        margin-top: var(--space-4);
    }

    .waiting-box h4 { margin-bottom: var(--space-3); font-size: var(--font-size-base); }

    .waiting-players {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        justify-content: center;
        margin-top: var(--space-3);
    }

    .wp-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
    }

    .wp-done { background: #d1fae5; color: #065f46; }
    .wp-pending { background: #f3f4f6; color: #6b7280; }

    .btn-next {
        position: fixed;
        bottom: var(--space-6);
        right: var(--space-6);
        padding: var(--space-3) var(--space-6);
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-bold);
        border: none;
        border-radius: 999px;
        background: var(--gradient-primary);
        color: white;
        cursor: pointer;
        box-shadow: var(--shadow-primary);
        transition: all var(--transition-base);
        display: flex;
        align-items: center;
        gap: var(--space-2);
        z-index: 50;
    }

    .btn-next:hover { transform: scale(1.05); }
    .btn-next:disabled { opacity: .5; cursor: not-allowed; transform: none; }

    .spinner {
        width: 18px; height: 18px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin .8s linear infinite;
        display: inline-block;
    }

    .alert-error {
        background: #fef2f2; border: 1px solid #fecaca;
        color: #991b1b; border-radius: var(--radius-md);
        padding: var(--space-3) var(--space-4);
        margin-bottom: var(--space-4); font-size: var(--font-size-sm);
    }

    .disconnected-banner {
        background: #fffbeb; border: 1px solid #fcd34d;
        color: #92400e; border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-4);
        margin-bottom: var(--space-3); font-size: var(--font-size-sm);
        text-align: center;
    }

    .scoreboard-title {
        font-size: var(--font-size-sm);
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-neutral-500);
        font-weight: var(--font-weight-semibold);
        margin-bottom: var(--space-3);
    }

    .score-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius-md);
        margin-bottom: var(--space-2);
        background: var(--color-neutral-50);
    }

    .score-name { font-weight: var(--font-weight-semibold); font-size: var(--font-size-sm); }
    .score-pts { font-weight: var(--font-weight-bold); color: var(--color-primary-600); }
    .score-king-badge { font-size: 10px; margin-left: 4px; }

    .loading-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: var(--space-4);
        color: var(--color-neutral-500);
    }

    .big-spinner {
        width: 48px; height: 48px;
        border: 4px solid var(--color-primary-100);
        border-top-color: var(--color-primary-600);
        border-radius: 50%;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
    @@keyframes slideInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    @@media (max-width: 700px) {
        .game-layout { grid-template-columns: 1fr; }
    }
</style>

<div class="game-wrapper">

@if (phase == Phase.Loading)
{
    <div class="loading-center">
        <div class="big-spinner"></div>
        <p>Loading game…</p>
    </div>
}
else if (phase == Phase.GameOver)
{
    <GameComplete Scoreboard="@finalScores"
                  KingPlayerName="@kingPlayerName"
                  OnNewGame="@(() => NavigationManager.NavigateTo("/"))"
                  OnViewLeaderboard="@(() => NavigationManager.NavigateTo("/leaderboard"))" />
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert-error" style="max-width:900px;margin:0 auto var(--space-3)">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(disconnectedMessage))
    {
        <div class="disconnected-banner" style="max-width:900px;margin:0 auto var(--space-3)">@disconnectedMessage</div>
    }

    <div class="game-layout">
        <!-- Main game card -->
        <div class="card">
            <span class="round-badge">Round @(roundIndex + 1) of @maxRounds</span>

            @if (phase == Phase.Results)
            {
                <RoundResults KingAnswer="@kingAnswer"
                              PlayerAnswers="@playerAnswers"
                              MatchedPlayers="@matchedPlayers"
                              KingPlayerName="@kingPlayerName"
                              OnNextRound="@NextRound" />
            }
            else
            {
                <!-- Role pill -->
                <div class="role-pill @(amKing ? "role-king" : "role-guesser")">
                    @if (amKing)
                    {
                        <span>👑 You are the King — give your honest answers!</span>
                    }
                    else
                    {
                        <span>🎯 Guesser — try to match what @kingPlayerName answers</span>
                    }
                </div>

                <div class="question-text">@questionText</div>

                <!-- Answer area -->
                @if (!hasSubmitted)
                {
                    <div class="answer-area">
                        <textarea class="answer-input"
                                  rows="3"
                                  placeholder="@(amKing ? "Type your answer — guessers will try to match it…" : "What do you think the King answered?")"
                                  @bind="myAnswer"
                                  @bind:event="oninput"
                                  @onkeydown="HandleKeyDown"
                                  disabled="@isSubmitting"></textarea>
                        <button class="btn-submit"
                                @onclick="SubmitAnswer"
                                disabled="@(string.IsNullOrWhiteSpace(myAnswer) || isSubmitting)">
                            @if (isSubmitting) { <div class="spinner"></div> }
                            else { <span>Submit Answer</span> }
                        </button>
                    </div>
                }

                <!-- Waiting overlay (shown after submit) -->
                @if (hasSubmitted)
                {
                    <div class="waiting-box">
                        <h4>✓ Answer submitted!</h4>
                        <p style="font-size: var(--font-size-sm); margin-bottom: 0">
                            Waiting for @(allPlayers.Count - answeredPlayers.Count) more player(s)…
                        </p>
                        <div class="waiting-players">
                            @foreach (var p in allPlayers)
                            {
                                var done = answeredPlayers.Contains(p) || p == myName;
                                <span class="wp-chip @(done ? "wp-done" : "wp-pending")">
                                    @if (done) { <span>✓</span> } else { <span>⋯</span> }
                                    @p
                                </span>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Sidebar: live scoreboard -->
        <div>
            <div class="card">
                <div class="scoreboard-title">Scores</div>
                @foreach (var (name, score) in scores.Where(x => x.Key != kingPlayerName).OrderByDescending(x => x.Value))
                {
                    <div class="score-row">
                        <span class="score-name">@name</span>
                        <span class="score-pts">@score</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Next Round FAB (host only, shown after results) -->
@if (phase == Phase.Results && Hub.IsHost)
{
    <button class="btn-next" @onclick="NextRound" disabled="@isAdvancing">
        @if (isAdvancing) { <div class="spinner"></div> }
        else { <span>Next Round →</span> }
    </button>
}

</div>

@code {
    [Parameter] public string GameCode { get; set; } = "";

    private enum Phase { Loading, Answering, WaitingForOthers, Results, GameOver }

    private Phase phase = Phase.Loading;
    private string myName = "";
    private bool amKing = false;
    private string kingPlayerName = "";
    private string questionText = "";
    private int roundIndex = 0;
    private int maxRounds = 5;
    private List<string> allPlayers = new();
    private Dictionary<string, int> scores = new();
    private HashSet<string> answeredPlayers = new();
    private bool hasSubmitted = false;
    private string myAnswer = "";
    private bool isSubmitting = false;
    private bool isAdvancing = false;
    private string errorMessage = "";
    private string disconnectedMessage = "";

    // Results data
    private string kingAnswer = "";
    private Dictionary<string, string> playerAnswers = new();
    private List<string> matchedPlayers = new();
    private Dictionary<string, int> finalScores = new();

    // Named delegate fields for lambdas so Dispose() can unsubscribe them
    private Action<LobbyUpdateInfo>? _onPlayerDisconnected;
    private Action<string, string>? _onHostChanged;

    protected override async Task OnInitializedAsync()
    {
        myName = Hub.MyPlayerName;

        if (string.IsNullOrEmpty(myName) || !Hub.IsConnected)
        {
            // Page was refreshed — no SignalR session, redirect home
            NavigationManager.NavigateTo("/");
            return;
        }

        // Subscribe to hub events
        _onPlayerDisconnected = update =>
        {
            if (!update.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;
            disconnectedMessage = $"A player disconnected. {allPlayers.Count - update.Players.Count} player(s) left.";
            allPlayers = update.Players;
            InvokeAsync(StateHasChanged);
        };
        _onHostChanged = (code, newHost) =>
        {
            if (!code.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;
            InvokeAsync(StateHasChanged); // Hub.IsHost was already updated in service
        };

        Hub.OnGameStarted += HandleGameStarted;
        Hub.OnRoundStarted += HandleRoundStarted;
        Hub.OnAnswerRecorded += HandleAnswerRecorded;
        Hub.OnRoundResult += HandleRoundResult;
        Hub.OnGameOver += HandleGameOver;
        Hub.OnGameError += HandleGameError;
        Hub.OnPlayerDisconnected += _onPlayerDisconnected;
        Hub.OnHostChanged += _onHostChanged;

        // GameStarted may have fired while Lobby.razor was navigating to this page.
        // Seed state from the cache so we don't hang on the loading screen.
        if (Hub.CurrentGame is { } cached &&
            cached.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase))
        {
            HandleGameStarted(cached);
        }
    }

    // ── Hub event handlers ──────────────────────────────────────────────────

    private void HandleGameStarted(GameStartedInfo info)
    {
        if (!info.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;
        ApplyRoundState(
            info.RoundIndex, info.MaxRounds,
            info.KingPlayerName,
            info.Players.Select(p => p.Name).ToList(),
            info.Players.ToDictionary(p => p.Name, p => p.Score),
            info.QuestionText);
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoundStarted(RoundStartedInfo info)
    {
        if (!info.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;
        ApplyRoundState(
            info.RoundIndex, info.MaxRounds,
            info.KingPlayerName,
            info.Players.Select(p => p.Name).ToList(),
            info.Players.ToDictionary(p => p.Name, p => p.Score),
            info.QuestionText);
        InvokeAsync(StateHasChanged);
    }

    private void HandleAnswerRecorded(string playerName, int ri)
    {
        if (ri != roundIndex) return;
        answeredPlayers.Add(playerName);
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoundResult(RoundResultInfo info)
    {
        if (!info.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;

        kingAnswer = info.KingAnswer;
        matchedPlayers = info.MatchedPlayers;
        scores = info.Scores;

        // Build PlayerAnswers dict from server players+answers (server doesn't expose raw answers by design,
        // but we can build a display-only one from matched/unmatched info)
        playerAnswers = new Dictionary<string, string>();
        foreach (var p in info.Players.Where(p => !p.IsKingPlayer))
        {
            // We don't have individual answers server→client (privacy); show only matched flag
            playerAnswers[p.Name] = "";  // RoundResults component will use MatchedPlayers to show icons
        }

        phase = Phase.Results;
        isAdvancing = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameOver(GameOverInfo info)
    {
        if (!info.GameCode.Equals(GameCode, StringComparison.OrdinalIgnoreCase)) return;
        finalScores = info.FinalScores;
        phase = Phase.GameOver;
        // Host saves game history
        if (Hub.IsHost)
            InvokeAsync(() => SaveGameHistoryAsync(info));
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        isSubmitting = false;
        isAdvancing = false;
        errorMessage = msg;
        InvokeAsync(StateHasChanged);
    }

    // ── Helpers ─────────────────────────────────────────────────────────────

    private void ApplyRoundState(int ri, int mr, string king, List<string> players,
                                  Dictionary<string, int> sc, string question)
    {
        roundIndex = ri;
        maxRounds = mr;
        kingPlayerName = king;
        allPlayers = players;
        scores = sc;
        questionText = question;
        amKing = myName.Equals(king, StringComparison.OrdinalIgnoreCase);
        answeredPlayers.Clear();
        hasSubmitted = false;
        myAnswer = "";
        isSubmitting = false;
        phase = Phase.Answering;
        errorMessage = "";
        disconnectedMessage = "";
    }

    private async Task SubmitAnswer()
    {
        if (string.IsNullOrWhiteSpace(myAnswer)) return;
        isSubmitting = true;
        errorMessage = "";
        StateHasChanged();
        try
        {
            await Hub.SubmitAnswerAsync(GameCode, myAnswer.Trim(), roundIndex);
            hasSubmitted = true;
            answeredPlayers.Add(myName); // count ourselves immediately
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SubmitAnswer failed");
            errorMessage = "Failed to submit answer. Please try again.";
        }
        isSubmitting = false;
        StateHasChanged();
    }

    private async Task NextRound()
    {
        if (!Hub.IsHost) return;
        isAdvancing = true;
        errorMessage = "";
        StateHasChanged();
        try { await Hub.RequestNextRoundAsync(GameCode); }
        catch (Exception ex)
        {
            Logger.LogError(ex, "RequestNextRound failed");
            errorMessage = "Failed to advance round. Please try again.";
            isAdvancing = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey && !string.IsNullOrWhiteSpace(myAnswer))
            await SubmitAnswer();
    }

    private async Task SaveGameHistoryAsync(GameOverInfo info)
    {
        try
        {
            var playerNamesStr = string.Join(", ", info.Players.Select(p => p.Name));
            var totalScore = info.FinalScores.Values.Sum();
            var history = new GameHistory
            {
                GameSessionId = GameCode,
                Date = DateTime.UtcNow,
                Team1Name = playerNamesStr,
                Team2Name = "",
                Team1Score = totalScore,
                Team2Score = 0,
                TotalQuestions = maxRounds,
                AverageResponseTime = 30.0
            };
            await GameHistoryService.SaveGameHistoryAsync(history);

            // Update per-player leaderboard stats
            foreach (var p in info.Players)
            {
                int pts = info.FinalScores.TryGetValue(p.Name, out var s) ? s : 0;
                int correct = pts / GameEngine.PointsPerCorrectAnswer;
                await TeamService.UpdateTeamStatsAsync(p.Name, pts, maxRounds, correct);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Non-critical: failed to save game history");
        }
    }

    public void Dispose()
    {
        Hub.OnGameStarted -= HandleGameStarted;
        Hub.OnRoundStarted -= HandleRoundStarted;
        Hub.OnAnswerRecorded -= HandleAnswerRecorded;
        Hub.OnRoundResult -= HandleRoundResult;
        Hub.OnGameOver -= HandleGameOver;
        Hub.OnGameError -= HandleGameError;
        if (_onPlayerDisconnected is not null) Hub.OnPlayerDisconnected -= _onPlayerDisconnected;
        if (_onHostChanged       is not null) Hub.OnHostChanged       -= _onHostChanged;
    }
}
